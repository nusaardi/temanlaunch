NODE_ENV=production
PORT=10000

# Render injects this automatically when using render.yaml.
DATABASE_URL=

# Required secrets
JWT_SECRET=
AI_CREDENTIALS_ENCRYPTION_KEY=

# Public browser origins
CORS_ORIGINS=https://temanlaunch.my.id,https://www.temanlaunch.my.id
CORS_ALLOW_RENDER_ORIGINS=true

# Optional admin usernames
ADMIN_USERNAMES=

# Credits and demo-friendly defaults
ENFORCE_CREDITS=false
DEFAULT_FREE_CREDITS=200
INPUT_TOKEN_COST_USD_PER_1K=0
OUTPUT_TOKEN_COST_USD_PER_1K=0

# Default managed AI provider
AI_DEFAULT_PROVIDER=bedrock_dev
AWS_REGION=us-east-1
MODEL_ID=us.anthropic.claude-sonnet-4-6

# Optional Bedrock credentials for internal-credit mode
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
